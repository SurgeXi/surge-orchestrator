# Copy to .env for local dev. Never commit .env.
SOL_ENVIRONMENT=dev
SOL_PORT=9320
SOL_HOST=127.0.0.1
SOL_ENFORCE=false
SOL_SHADOW_ENABLED=true
SOL_DATABASE_URL=postgresql+psycopg2://sol_user:CHANGEME@127.0.0.1:5432/surge_brain
